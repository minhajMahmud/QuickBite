# QuickBite Database Environment Variables
# Copy this to .env and modify values as needed

# PostgreSQL Configuration
DB_USER=quickbite_user
DB_PASSWORD=quickbite_password_2024
DB_NAME=quickbite
DB_HOST=postgres
DB_PORT=5432

# pgAdmin Configuration
PGADMIN_EMAIL=admin@quickbite.com
PGADMIN_PASSWORD=admin_password_2024

# Database Initialization
POSTGRES_INITDB_ARGS=--encoding=UTF8

# Application Environment
ENV=development
LOG_LEVEL=info
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=3000
API_URL=http://localhost:3000

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# File Upload
MAX_UPLOAD_SIZE=10242880
UPLOAD_DIR=./uploads

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@quickbite.com

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your_session_secret_key_here
SESSION_TIMEOUT=3600000

# Redis Configuration (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Payment Gateway (Optional)
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key

# Map Configuration (Optional)
MAPS_API_KEY=your_google_maps_key

# Third-party Services
SENTRY_DSN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# resend api key
RESEND_API_KEY=